        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse the response\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// Save the token to an environment or collection variable\r",
              "pm.collectionVariables.set(\"authToken\", jsonData.token);\r",
              "\r",
              "// Optional: Log for confirmation\r",
              "console.log(\"Token saved:\", jsonData.token);\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
