    {
      "name": "DeleteBooking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test that the delete operation was successful",
              "pm.test(\"Delete operation successful\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
              "});",
              "",
              "// Verify the booking no longer exists by making a GET request",
              "const bookingId = pm.collectionVariables.get(\"bookingid\");",
              "const verificationUrl = `https://restful-booker.herokuapp.com/booking/${bookingId}`;",
              "",
              "pm.sendRequest(verificationUrl, function (err, response) {",
              "    pm.test(\"Booking no longer exists after deletion\", function () {",
              "        pm.expect(response.code).to.equal(404);",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
