    {
      "name": "GetBookingByID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "// 1. Data Integrity\r",
              "pm.test(\"Data Integrity: Firstname matches created booking\", function () {\r",
              "    const expectedName = pm.environment.get(\"temp_firstname\");\r",
              "    pm.expect(jsonData.firstname).to.eql(expectedName);\r",
              "});\r",
              "\r",
              "// 2. Verification dates format\r",
              "pm.test(\"Booking dates format check\", function () {\r",
              "    pm.expect(jsonData.bookingdates.checkin).to.be.a('string');\r",
              "    pm.expect(jsonData.bookingdates.checkout).to.be.a('string');\r",
              "});\r",
              "\r",
              "// 3. Status check\r",
              "pm.test(\"Booking retrieved - Status 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
